# OS
.DS_Store
Thumbs.db

# DB volume（bind mount を使う場合）
db_data/

# secrets / 環境変数（GitHub token・DB認証情報を絶対にコミットしない）
.env
.env.*
!.env.example

# editor / IDE
.vscode/
.idea/
.obsidian/

# PHP dependencies
vendor/
.phpunit.cache/

# 非公開の裏方（メモ・ハンドオフ・構成計画）はフォルダごと repo に出さない
/private/

# ユーザーアップロード: 実体はコミットしない（.htaccess の security 設定だけ追跡）
public/uploads/*
!public/uploads/.htaccess
